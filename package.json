{
  "name": "forge",
  "version": "0.1.0-phase0",
  "private": true,
  "description": "Forge — a distributed job scheduling platform (Phase 0: Foundation)",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "dev:worker": "tsx watch src/worker/server.ts",
    "dev:scheduler": "tsx watch src/scheduler/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/api/server.js",
    "start:worker": "node dist/worker/server.js",
    "start:scheduler": "node dist/scheduler/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run tests/**/*.integration.test.ts",
    "test:integration:setup": "docker compose up -d postgres redis && tsx scripts/wait-for-db.ts && prisma db push --skip-generate",
    "test:integration:ci": "npm run test:integration:setup && npm run test:integration",
    "test:watch": "vitest",
    "load-test": "tsx scripts/load-test.ts",
    "autoscale-sim": "tsx scripts/autoscale-sim.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.5.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.16.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.20.0",
    "supertest": "^6.3.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
