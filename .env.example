# Copy to .env and fill in real values. Never commit .env itself.

# api, scheduler, worker
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge

# api only — required, no default (Section 14.8 / Table 78)
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL=7d

# api
PORT=4000
CORS_ALLOWED_ORIGIN=http://localhost:5173
LOG_LEVEL=info
NODE_ENV=development

# api — optional; enables real AI failure summaries (Section 11.11).
# Without it, POST /v1/dlq/:id/summarize falls back to a rule-based stub
# summary so the feature is still fully exercisable offline.
ANTHROPIC_API_KEY=

# worker, scheduler, api — coordination layer (Section 5)
REDIS_URL=redis://localhost:6379

# worker
WORKER_CAPACITY=5
POLL_INTERVAL_MS=1000
HEARTBEAT_INTERVAL_MS=10000
VISIBILITY_TIMEOUT_SECONDS=30
SHUTDOWN_GRACE_PERIOD_MS=30000

# scheduler
SCHEDULER_TICK_MS=500
REAPER_TICK_MS=5000
METRICS_TICK_MS=30000
WORKER_TIMEOUT_MS=30000
